# AI provider: anthropic | kimi | mentor
AI_PROVIDER=anthropic

# Anthropic (direct — when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Mentor API — one key, many models (https://platform.thementorprogram.xyz)
# Keys start with mnt_...  OpenAI-compatible base URL.
MENTOR_API_KEY=mnt_...
MENTOR_BASE_URL=https://platform.thementorprogram.xyz/api/v1

# Moonshot / Kimi direct (when AI_PROVIDER=kimi)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Required — Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Required — Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Clerk routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Model + token caps
# anthropic:  claude-haiku-4-5-20251001
# kimi:       kimi-k2.5
# mentor:     openai/gpt-4o-mini (recommended) | openai/gpt-4.1-nano
AI_MODEL=openai/gpt-4o-mini
AI_MAX_OUTPUT_TOKENS=1024
KIMI_THINKING=disabled
